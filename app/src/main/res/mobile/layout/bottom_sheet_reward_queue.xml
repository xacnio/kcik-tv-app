<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#141414"
    android:orientation="vertical">

    <!-- Main header (always visible) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_reward_queue"
            app:tint="@color/brand_green" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="12dp"
            android:text="@string/reward_queue_title"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/rewardQueueLoading"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:indeterminateTint="@color/brand_green"
            android:visibility="gone"
            tools:visibility="visible" />

        <ImageButton
            android:id="@+id/rewardQueueRefreshButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_item_ripple"
            android:contentDescription="@string/retry"
            android:padding="6dp"
            android:src="@drawable/ic_refresh"
            app:tint="#CCCCCC" />

        <ImageButton
            android:id="@+id/rewardQueueCloseButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_item_ripple"
            android:contentDescription="@string/close"
            android:padding="6dp"
            android:src="@drawable/ic_close"
            app:tint="#CCCCCC" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#222222" />

    <!-- ViewFlipper: panel 0 = reward list, panel 1 = redemptions -->
    <ViewFlipper
        android:id="@+id/rewardQueueFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Panel 0: Reward / category list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rewardChipsRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingVertical="4dp"
            tools:listitem="@layout/item_reward_chip" />

        <!-- Panel 1: Redemptions for selected reward -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Sub-header: back button + reward title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp"
                android:paddingVertical="10dp">

                <ImageButton
                    android:id="@+id/redemptionsBackButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_item_ripple"
                    android:contentDescription="@string/close"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#CCCCCC" />

                <TextView
                    android:id="@+id/redemptionsRewardTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingStart="8dp"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="test2" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#222222" />

            <!-- Pause toggle row (hidden for "All rewards") -->
            <LinearLayout
                android:id="@+id/rewardPauseRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/reward_queue_pause_redemptions"
                    android:textColor="#DDDDDD"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/rewardPauseSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:id="@+id/rewardPauseDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#222222"
                android:visibility="gone" />

            <!-- Selection + pagination bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A1A1A"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp">

                <CheckBox
                    android:id="@+id/redemptionsSelectAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/brand_green"
                    android:text="@string/reward_queue_select_all"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/redemptionsPrevButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_item_ripple"
                    android:contentDescription="Prev"
                    android:padding="6dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#CCCCCC" />

                <TextView
                    android:id="@+id/redemptionsPagination"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:minWidth="50dp"
                    android:gravity="center"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    tools:text="1 / 45" />

                <ImageButton
                    android:id="@+id/redemptionsNextButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_item_ripple"
                    android:contentDescription="Next"
                    android:padding="6dp"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="#CCCCCC" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1C1C1C" />

            <!-- Redemptions list + empty state -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rewardRedemptionsRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingVertical="6dp"
                    tools:listitem="@layout/item_reward_redemption" />

                <LinearLayout
                    android:id="@+id/rewardQueueEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:alpha="0.35"
                        android:src="@drawable/ic_reward_queue"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="@string/reward_queue_empty"
                        android:textColor="#888888"
                        android:textSize="14sp" />
                </LinearLayout>
            </FrameLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#222222" />

            <!-- Footer action bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp">

                <Button
                    android:id="@+id/rewardQueueCompleteAllButton"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_mature_exit"
                    android:text="@string/reward_queue_complete_all"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/rewardQueueRejectAllButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_reward_queue_destructive"
                    android:text="@string/reward_queue_reject_all"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </ViewFlipper>
</LinearLayout>
