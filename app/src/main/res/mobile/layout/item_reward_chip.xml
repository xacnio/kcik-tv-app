<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rewardChipRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_reward_chip_row"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="14dp">

    <!-- Green left selection bar -->
    <View
        android:id="@+id/rewardChipSelectionBar"
        android:layout_width="3dp"
        android:layout_height="20dp"
        android:layout_marginEnd="12dp"
        android:background="@color/brand_green"
        android:visibility="invisible" />

    <TextView
        android:id="@+id/rewardChipTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        tools:text="All rewards" />

    <TextView
        android:id="@+id/rewardChipBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:background="#22FFFFFF"
        android:gravity="center"
        android:minWidth="24dp"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:textColor="#CCCCCC"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:text="2" />

    <TextView
        android:id="@+id/rewardChipPausedBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="#33FF9900"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:text="@string/reward_queue_paused_badge"
        android:textColor="#FF9900"
        android:textSize="11sp"
        android:visibility="gone" />
</LinearLayout>
